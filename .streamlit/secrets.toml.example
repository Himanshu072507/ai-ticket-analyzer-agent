# Copy this file to secrets.toml and fill in your keys for local dev,
# OR paste these lines into the "Secrets" editor on share.streamlit.io
# (App settings -> Secrets) when deploying to Streamlit Community Cloud.
#
# Both keys are optional. Provide at least one of GEMINI_API_KEY or
# GROQ_API_KEY so the deployed app can produce AI insights.

GEMINI_API_KEY = "your-gemini-api-key-here"
GROQ_API_KEY = "your-groq-api-key-here"
